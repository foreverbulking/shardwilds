# Shardwilds environment variables.
# Copy this file to .env and fill in the values. Never commit .env (it is gitignored).

# --- GitHub ---
# Used by the GitHub MCP server. Create a fine-scoped personal access token at:
#   https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- SpacetimeDB (local) ---
# Used once the server module exists (STORY-003).
SPACETIMEDB_HOST=http://localhost:3000
SPACETIMEDB_MODULE=shardwilds
